{
  "name": "@tanuden/rudolf",
  "version": "0.1.1",
  "description": "Universal wire-format standard for communication between Japanese train simulators and external programs.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/haruyukitanuki/rudolf-ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haruyukitanuki/rudolf-ts.git"
  },
  "bugs": {
    "url": "https://github.com/haruyukitanuki/rudolf-ts/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:types": "attw --pack ."
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@microsoft/api-extractor": "^7.52.8",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-unicorn": "^70.0.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3"
  }
}
